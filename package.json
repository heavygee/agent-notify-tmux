{
  "name": "agent-notify",
  "version": "2.5.1",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun src/index.ts",
    "build": "bun build --compile --minify --sourcemap src/index.ts --outfile dist/agent-notify",
    "test": "bun test",
    "test:ci": "bun test",
    "scan:secrets": "docker run --rm -v \"$PWD\":/path zricethezav/gitleaks:latest detect --source /path --verbose --redact --exit-code 1"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@clack/core": "1.0.0-alpha.7",
    "@clack/prompts": "1.0.0-alpha.7",
    "diff": "^8.0.3",
    "picocolors": "^1.1.1"
  }
}
